modules = ["python-3.12", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["ffmpeg", "ffmpeg-full", "freetype", "git", "gmp", "lcms2", "libGL", "libGLU", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "libyaml", "mesa", "openjpeg", "tcl", "tk", "xorg.libX11", "xorg.libXext", "xorg.libxcb", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AnnieMusic Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Annie Web UI"

[[workflows.workflow]]
name = "AnnieMusic Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m ANNIEMUSIC"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Annie Web UI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python webserver.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

