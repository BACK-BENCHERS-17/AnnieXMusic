modules = ["python-3.12", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["ffmpeg", "git", "libGL", "libGLU", "mesa", "xorg.libxcb", "xorg.libX11", "xorg.libXext"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AnnieMusic Bot"

[[workflows.workflow]]
name = "AnnieMusic Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m ANNIEMUSIC"

[workflows.workflow.metadata]
outputType = "console"

